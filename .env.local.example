# Neon Postgres — use pooled connection string from Neon Console
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Upstash Redis — from Upstash Console -> REST API section
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxx..."

# Your app URL — used for generating shareable event links on the confirmation page
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend — from Resend Dashboard -> API Keys
RESEND_API_KEY="re_xxx..."

# Vercel Cron secret — must match CRON_SECRET in Vercel project settings
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
